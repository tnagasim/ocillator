### Step 5: `cmd/ocillator/main.go` 実装

```go
package main

import (
    "github.com/spf13/cobra"
    "os"
)

func main() {
    rootCmd := &cobra.Command{
        Use:     "ocillator",
        Short:   "OCI image distribution tool for air-gapped environments",
        Version: "v0.0.1",
    }

    syncCmd := &cobra.Command{
        Use:   "sync",
        Short: "Sync OCI images",
        RunE: func(cmd *cobra.Command, args []string) error {
            return nil
        },
    }

    releaseCmd := &cobra.Command{
        Use:   "release",
        Short: "Manage releases",
        RunE: func(cmd *cobra.Command, args []string) error {
            return nil
        },
    }

    deployCmd := &cobra.Command{
        Use:   "deploy",
        Short: "Deploy images",
        RunE: func(cmd *cobra.Command, args []string) error {
            return nil
        },
    }

    rootCmd.AddCommand(syncCmd, releaseCmd, deployCmd)

    if err := rootCmd.Execute(); err != nil {
        os.Exit(1)
    }
}
```

**検証:** `go run ./cmd/ocillator --help` と `go run ./cmd/ocillator --version` の両方が通ること。

### Step 6: `.github/workflows/build.yml` 作成

```yaml
name: Build

on:
  push:
  pull_request:

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: "1.24"
      - run: go test ./...

  build:
    needs: test
    runs-on: ubuntu-latest
    strategy:
      matrix:
        include:
          - goos: darwin
            goarch: arm64
            artifact: ocillator-darwin-arm64
          - goos: linux
            goarch: amd64
            artifact: ocillator-linux-amd64
          - goos: windows
            goarch: amd64
            artifact: ocillator-windows-amd64.exe
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: "1.24"
      - name: Build
        env:
          GOOS: ${{ matrix.goos }}
          GOARCH: ${{ matrix.goarch }}
        run: go build -o ${{ matrix.artifact }} ./cmd/ocillator
      - uses: actions/upload-artifact@v4
        with:
          name: ${{ matrix.artifact }}
          path: ${{ matrix.artifact }}
```

**検証:** `yamllint` または `actionlint` で YAML 構文確認。

